      env: env,
      key: "BUILT_PRODUCTS_DIR"
    )
    verifyFrameworkBuildMode(
      destinationDir: builtProductsDir,
      targetBuildMode: targetBuildMode
    )

    let targetBuildDir = FlutterToolHelper.findOrExit(
      env: env,
      key: "TARGET_BUILD_DIR"
    )
    let frameworksFolderPath = FlutterToolHelper.findOrExit(
      env: env,
      key: "FRAMEWORKS_FOLDER_PATH"
    )
    let embeddedFrameworks = (targetBuildDir as NSString)
      .appendingPathComponent(
        frameworksFolderPath
      )
    verifyFrameworkBuildMode(
      destinationDir: embeddedFrameworks,
      targetBuildMode: targetBuildMode
    )
  }

  static func verifyFrameworkBuildMode(
    destinationDir: String,
    targetBuildMode: String
  ) {
    let env = ProcessInfo.processInfo.environment

    let frameworkInfoPlistURL = flutterFrameworkInfoPlist(
      env: env,
      destinationDir: destinationDir
    )
    let expectedBuildMode = expectedBuildModeForSdk(
      env: env,
      targetBuildMode: targetBuildMode
    )
    let actualBuildMode = buildModeFromInfoPlist(
      frameworkInfoPlistURL: frameworkInfoPlistURL
    )

    // Verify expected and actual build mode matches
    if actualBuildMode.lowercased() != expectedBuildMode.lowercased() {
      FlutterToolHelper.xcodeError(
        message:
          "The Flutter framework's build mode does not match the currently targeted configuration. Expected \(expectedBuildMode) but found \(actualBuildMode) for \(frameworkInfoPlistURL.path)."
      )
      exit(1)
    }
  }

  static func flutterFrameworkInfoPlist(
    env: [String: String],
    destinationDir: String
  ) -> URL {
    let infoPlistRelativePath =
      (FlutterToolHelper.targetPlatform(env: env) == FlutterPlatform.macos)
      ? "FlutterMacOS.framework/Resources/Info.plist"
      : "Flutter.framework/Info.plist"

    return URL(fileURLWithPath: destinationDir)
      .appendingPathComponent(infoPlistRelativePath)
  }

  static func expectedBuildModeForSdk(
    env: [String: String],
    targetBuildMode: String
  ) -> String {
    let sdkRoot = FlutterToolHelper.findOrExit(env: env, key: "SDKROOT")
    if sdkRoot.lowercased().contains("simulator") {
      return "debug"
    }
    return targetBuildMode
  }

  static func buildModeFromInfoPlist(frameworkInfoPlistURL: URL) -> String {
