    let currentTargetURL = URL(fileURLWithPath: currentTarget)
    let currentBuildMode = currentTargetURL.deletingLastPathComponent()
      .lastPathComponent
    let pluginPath = URL(fileURLWithPath: flutterConfigurationPlugin).path
    let warningLines = [
      " The target build configuration is set to \(targetBuildMode), but Flutter packages are set to \(currentBuildMode).",
      "This project uses a remote Flutter framework and requires the build configuration to be switched manually. Please complete one of the following:",
      "  1) Right click on FlutterPluginRegistrant in Xcode's Project Navigator and select \"Switch to \(targetBuildMode) Mode\".",
