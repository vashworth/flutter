class FlutterFrameworkSync {
  {{^useRemoteFlutterFramework}}
  static func copy(targetBuildMode: String) {
    let env = ProcessInfo.processInfo.environment

    let flutterPluginRegistrantDir = FlutterToolHelper.findOrExit(
      env: env,
      key: "FLUTTER_PLUGIN_REGISTRANT_PATH"
    )
    let targetPlatform = FlutterToolHelper.targetPlatform(env: env)
    var frameworkName = "Flutter"
    if targetPlatform == FlutterPlatform.macos {
      frameworkName = "FlutterMacOS"
    }

    let fileManager = FileManager.default
    let xcframeworkURL = URL(
      fileURLWithPath:
        "\(flutterPluginRegistrantDir)/\(targetBuildMode)/Frameworks/\(frameworkName).xcframework"
    )
    if !fileManager.fileExists(atPath: xcframeworkURL.path) {
      FlutterToolHelper.xcodeError(
        message:
          "FlutterPluginRegistrant does not exist for configuration \(targetBuildMode). You may need to run \"flutter build swift-package --build-mode \(targetBuildMode.lowercased())\" in your Flutter app."
      )
      exit(1)
    }

    let simulator = simulatorSdk(env: env)
    do {
      for file in try fileManager.contentsOfDirectory(
        at: xcframeworkURL,
        includingPropertiesForKeys: nil
      ) {
        let archDir = file.lastPathComponent
        if !archDir.starts(with: "ios") {
          continue
        }
        if (archDir.hasSuffix("-simulator") && simulator)
          || (!archDir.hasSuffix("-simulator") && !simulator)
        {
          let frameworkPath = file.appendingPathComponent(
            "\(frameworkName).framework"
          )
          let builtProductsDir = FlutterToolHelper.findOrExit(
            env: env,
            key: "BUILT_PRODUCTS_DIR"
          )
          rsyncFramework(
            source: frameworkPath,
            destination: URL(fileURLWithPath: builtProductsDir)
          )
          break
        }
      }
    } catch {
      FlutterToolHelper.xcodeError(
        message:
          "Unable to copy \(xcframeworkURL): \(error.localizedDescription)"
      )
      exit(1)
    }
  }

  static func rsyncFramework(source: URL, destination: URL) {
    #if os(macOS)
      let process = Process()
      process.launchPath = "/usr/bin/rsync"
      process.arguments = [
        "-av", "--delete", "--filter", "- .DS_Store/",
        "--chmod=Du=rwx,Dgo=rx,Fu=rw,Fgo=r", source.path, destination.path,
      ]
      do {
        try process.run()
        process.waitUntilExit()
        if process.terminationStatus != 0 {
          exit(process.terminationStatus)
        }
      } catch {
        FlutterToolHelper.xcodeError(
          message:
            "Failed to run rsync: \(error.localizedDescription)"
        )
        exit(1)
      }
    #endif
  }

  static func simulatorSdk(env: [String: String]) -> Bool {
    let sdkRoot = FlutterToolHelper.findOrExit(env: env, key: "SDKROOT")
    let url = URL(fileURLWithPath: sdkRoot)
    let filenameWithExtension = url.lastPathComponent
    if !filenameWithExtension.contains("iphone") {
      FlutterToolHelper.xcodeError(message: "Unrecognized SDKROOT: \(sdkRoot). Flutter only supports iOS and macOS.")
      exit(1)
    }
    if filenameWithExtension.contains("simulator") {
      return true
    }
    return false
  }
